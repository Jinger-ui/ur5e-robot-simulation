# ===== ROBOT BASE PEDESTAL (from ur5e_pick.wbt) =====
SolidBox {
  translation 0 0 0.4
  name "robot_base"
  size 0.4 0.4 0.8
  appearance GalvanizedMetal {
  }
}

# ===== UR5e ROBOT (exact copy from ur5e_pick.wbt) =====
UR5e {
  translation 0 0 0.8
  rotation 0 0 1 -1.5708
  controller "ur5e_factory_controller"
  selfCollision FALSE
  toolSlot [
    Connector {
      translation 0 0.05 0
      rotation 1 0 0 -1.5708
      name "connector"
      model "magnetic"
      isLocked FALSE
      unilateralLock TRUE
      unilateralUnlock TRUE
      distanceTolerance 0.15
      axisTolerance 3.15
      rotationTolerance 3.15
      numberOfRotations 0
      snap TRUE
      tensileStrength -1
      shearStrength -1
    }
    GPS {
      translation 0 0.05 0
      name "tool_gps"
    }
  ]
}

# ===== PICK TABLE (from ur5e_pick.wbt) =====
Table {
  translation 0.5 0 0
  name "pick_table"
  size 0.8 0.8 0.74
  feetSize 0.04 0.04
  trayAppearance PBRAppearance {
    baseColor 0.82 0.82 0.78
    roughness 0.7
    metalness 0
  }
  legAppearance BrushedAluminium {
    colorOverride 0.35 0.35 0.33
  }
}

# ===== PLACE TABLE (from ur5e_pick.wbt) =====
Table {
  translation -0.5 0 0
  name "place_table"
  size 0.6 0.8 0.74
  feetSize 0.04 0.04
  trayAppearance PBRAppearance {
    baseColor 0.7 0.78 0.88
    roughness 0.7
    metalness 0
  }
  legAppearance BrushedAluminium {
    colorOverride 0.35 0.35 0.33
  }
}

# ===== TARGET OBJECTS (Connector-based, verified positions) =====
DEF TARGET_RED Solid {
  translation 0.45 0 0.775
