WorldInfo {
  info [
    "UR5e Factory Pick-and-Place Simulation"
    "Connector magnetic grasp + GPS calibration + factory environment"
  ]
  title "UR5e Factory Demo"
  basicTimeStep 16
  contactProperties [
    ContactProperties {
      bounce 0.02
    }
  ]
}
Viewpoint {
  orientation -0.28 0.62 0.73 0.85
  position -3.5 -3.0 3.8
  exposure 1.7
}
TexturedBackground {
  texture "factory"
}
TexturedBackgroundLight {
}
PointLight {
  attenuation 0 0 1
  intensity 0.5
  location 0 0 4
  castShadows TRUE
}

# ===== FACTORY FLOOR =====
Floor {
  size 8 6
  appearance ThreadMetalPlate {
  }
}

