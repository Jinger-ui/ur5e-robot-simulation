# ===== SIGNAL LIGHTS (decorative) =====
DEF SIGNAL_POLE Solid {
  translation 2 -1.6 0.75
  children [
    Shape {
      appearance PBRAppearance {
        baseColor 0.3 0.3 0.3
        roughness 0.4
        metalness 0.9
      }
      geometry Cylinder {
        height 1.5
        radius 0.025
      }
    }
  ]
  name "signal_pole"
  boundingObject Cylinder {
    height 1.5
    radius 0.025
  }
}
