    Shape {
      appearance PBRAppearance {
        baseColor 0.9 0.12 0.12
        roughness 0.3
        metalness 0.1
      }
      geometry Box {
        size 0.06 0.06 0.06
      }
    }
    Connector {
      translation 0 0 0.035
      name "target_conn_red"
      model "magnetic"
      isLocked TRUE
      distanceTolerance 0.15
      axisTolerance 3.15
      rotationTolerance 3.15
      numberOfRotations 0
      snap TRUE
      tensileStrength -1
      shearStrength -1
