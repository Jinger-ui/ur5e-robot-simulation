WorldInfo {
  info [
    "UR5e RL Grasping Training Environment"
    "Robotiq 3F Gripper + Connector for robust grasping"
  ]
  title "UR5e RL Grasp Training"
  basicTimeStep 16
  contactProperties [
    ContactProperties {
      coulombFriction [1.5]
      bounce 0.01
      softCFM 0.001
    }
  ]
}
Viewpoint {
  orientation -0.35 0.55 0.76 0.95
  position -2.5 -2.5 3.0
  exposure 1.7
}
