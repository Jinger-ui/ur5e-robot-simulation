WorldInfo {
  info [
    "UR5e Minimal Pick-and-Place with Connector (magnetic grasp)"
    "No IK - uses GPS-calibrated fixed joint angles"
  ]
  title "UR5e Connector Pick Demo"
  basicTimeStep 16
  contactProperties [
    ContactProperties {
      bounce 0.02
    }
  ]
}
Viewpoint {
  orientation -0.28 0.62 0.73 0.85
  position -2.8 -2.2 3.0
  exposure 1.7
}
TexturedBackground {
  texture "factory"
}
TexturedBackgroundLight {
}
